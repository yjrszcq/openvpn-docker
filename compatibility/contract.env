# Legacy schema 3 Shell contract. Go reads strict contract.json; keep both in
# sync until the production runtime cutover removes this executable format.
# Exact OpenVPN runtime versions verified with this image release.
OPENVPN_SUPPORTED_VERSIONS=2.7.5
OPENVPN_ADAPTER=openvpn-2.7
OPENVPN_TEMPLATE_FAMILY=openvpn-2.7
OPENVPN_REQUIRED_FEATURES=tls-crypt,data-ciphers,crl-verify,topology-subnet
