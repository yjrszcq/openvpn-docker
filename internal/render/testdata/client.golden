client
# ovpn-client-id: 11111111-1111-4111-8111-111111111111
# ovpn-client-name: laptop
dev tun
proto udp
remote vpn.example.test 1194

resolv-retry infinite
nobind

persist-key
persist-tun

remote-cert-tls server

data-ciphers AES-256-GCM:CHACHA20-POLY1305:AES-128-GCM

<ca>
TEST CA CERT
</ca>

<cert>
TEST CLIENT CERT
</cert>

<key>
TEST CLIENT KEY
</key>

<tls-crypt>
TEST TLS CRYPT KEY
</tls-crypt>
