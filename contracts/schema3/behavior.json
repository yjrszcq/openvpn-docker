    {"family": "ipv4", "protocol": "tcp", "endpoint": "vpn.example.test", "server_proto": "tcp4-server", "client_proto": "tcp4-client", "ipv6_only": false},
    {"family": "ipv6", "protocol": "udp", "endpoint": "2001:db8::10", "server_proto": "udp6", "client_proto": "udp6", "ipv6_only": true},
    {"family": "ipv6", "protocol": "tcp", "endpoint": "vpn6.example.test", "server_proto": "tcp6-server", "client_proto": "tcp6-client", "ipv6_only": true}
