{
  "contract_version": 1,
  "source": {
    "image_version": "3.2.0",
    "data_schema": 3,
    "implementation": ["bash", "python3"],
    "command_reference": "docs/en/v3/commands.md"
  },
  "exit_codes": [
    {"code": 0, "meaning": "success"},
    {"code": 1, "meaning": "general validation, dependency, or runtime failure"},
    {"code": 64, "meaning": "unknown command or explicitly classified CLI usage failure"},
    {"code": 78, "meaning": "schema gate or critical/unrecoverable state refusal"}
  ],
  "defaults": {
    "OVPN_DATA_DIR": "/etc/openvpn",
    "OVPN_RUNTIME_DIR": "/run/openvpn-container",
    "OVPN_SERVER_NAME": "openvpn-server",
    "OVPN_CONFIG_VERSION": "3",
    "OVPN_ENDPOINT": "",
    "OVPN_PROTO": "udp",
    "OVPN_TRANSPORT_FAMILY": "auto",
    "OVPN_PORT": "1194",
    "OVPN_NETWORK": "10.8.0.0/24",
    "OVPN_TOPOLOGY": "subnet",
    "OVPN_DYNAMIC_POOL_SIZE": "half of usable client capacity",
    "OVPN_NAT": "false",
    "OVPN_NAT_INTERFACE": "auto",
    "OVPN_REDIRECT_GATEWAY": "false",
    "OVPN_CLIENT_TO_CLIENT": "true",
    "OVPN_DNS": "",
    "OVPN_ROUTES": "",
    "OVPN_LOG_MAX_BYTES": "10485760",
    "OVPN_LOG_BACKUPS": "5",
    "OVPN_CRITICAL_MODE": "exit"
  },
  "identity": {
    "client_name_pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$",
    "uuid_version": 4,
    "minimum_id_prefix": 8,
    "default_display_prefix": 12,
    "current_name_unique": true,
    "deleted_tombstone_retained": true
  },
  "ipam": {
    "family": 4,
    "minimum_prefix": 30,
    "maximum_prefix": 0,
    "server_offset": 1,
    "first_client_offset": 2,
    "reserved_addresses": ["network", "server", "broadcast"],
    "dynamic_pool_position": "contiguous tail of usable client range",
    "default_dynamic_pool": "floor(usable_client_capacity / 2)",
    "boundary_cases": [
      {"network": "10.88.0.0/30", "capacity": 1, "default_dynamic": 0},
      {"network": "10.88.0.0/24", "capacity": 253, "default_dynamic": 126},
      {"network": "0.0.0.0/0", "capacity": 4294967293, "default_dynamic": 2147483646}
    ]
  },
  "state_classes": [
    "EMPTY",
    "HEALTHY",
    "DEGRADED_REPAIRABLE",
    "DEGRADED_RECOVERABLE",
    "DEGRADED_REISSUABLE",
    "CRITICAL",
    "UNRECOVERABLE"
  ],
  "schema_gate_states": [
    "EMPTY",
    "CURRENT",
    "CURRENT_INCOMPLETE",
    "OLD",
    "NEWER",
    "CONFLICT",
    "INVALID",
    "UNKNOWN"
  ],
  "commands": [
    {"v3": "ovpn init", "v4": "ovpn server init", "disposition": "redesign"},
    {"v3": "ovpn start", "v4": "ovpn server run", "disposition": "redesign"},
    {"v3": "ovpn config show", "v4": "ovpn config show", "disposition": "redesign"},
    {"v3": "ovpn config apply", "v4": "ovpn config apply --yes", "disposition": "redesign"},
    {"v3": "ovpn client create", "v4": "ovpn client create", "disposition": "redesign"},
    {"v3": "ovpn client export", "v4": "ovpn client export", "disposition": "redesign"},
    {"v3": "ovpn client list", "v4": "ovpn client list", "disposition": "preserve"},
    {"v3": "ovpn client rename", "v4": "ovpn client rename", "disposition": "redesign"},
    {"v3": "ovpn client revoke", "v4": "ovpn client revoke", "disposition": "redesign"},
    {"v3": "ovpn client reissue", "v4": "ovpn client reissue", "disposition": "redesign"},
    {"v3": "ovpn client delete", "v4": "ovpn client delete --yes", "disposition": "redesign"},
    {"v3": "ovpn client ip release", "v4": "ovpn client address release", "disposition": "redesign"},
    {"v3": "ovpn client ip set", "v4": "ovpn client address set/edit", "disposition": "redesign"},
    {"v3": "ovpn network plan", "v4": "ovpn config plan", "disposition": "fold"},
    {"v3": "ovpn network apply", "v4": "ovpn config apply --yes", "disposition": "fold"},
    {"v3": "ovpn repair plan", "v4": "ovpn repair plan", "disposition": "preserve"},
    {"v3": "ovpn repair apply", "v4": "ovpn repair apply --yes", "disposition": "redesign"},
    {"v3": "ovpn state show", "v4": "ovpn state show", "disposition": "preserve"},
    {"v3": "ovpn state doctor", "v4": "ovpn state doctor", "disposition": "preserve"},
    {"v3": "ovpn render server", "v4": "ovpn server render", "disposition": "redesign"},
    {"v3": "ovpn render client", "v4": "ovpn client export", "disposition": "fold"},
    {"v3": "ovpn runtime status", "v4": "ovpn runtime status", "disposition": "preserve"},
    {"v3": "ovpn runtime health", "v4": "ovpn runtime health", "disposition": "preserve"},
    {"v3": "ovpn runtime capabilities", "v4": "ovpn runtime capabilities", "disposition": "preserve"},
    {"v3": "ovpn runtime version", "v4": "ovpn version --json", "disposition": "fold"},
    {"v3": "ovpn runtime logs", "v4": "ovpn runtime logs", "disposition": "preserve"},
    {"v3": "ovpn runtime events", "v4": "ovpn runtime events", "disposition": "preserve"},
    {"v3": "ovpn migrate plan", "v4": "ovpn migrate plan", "disposition": "redesign"},
    {"v3": "ovpn migrate apply --yes", "v4": "ovpn migrate apply --yes", "disposition": "redesign"},
    {"v3": "ovpn -v/--version", "v4": "ovpn version --short/--json", "disposition": "redesign"}
  ],
  "persistent_layout": [
    {"path": "config/project.env", "role": "structured authority", "v4": "import into SQLite applied_config then remove"},
    {"path": "config/schema-version", "role": "structured authority", "v4": "import into SQLite schema_metadata then remove"},
    {"path": "meta/instance.json", "role": "structured authority", "v4": "import into SQLite instances then remove"},
    {"path": "meta/instance-id", "role": "structured authority", "v4": "import into SQLite instances then remove"},
    {"path": "meta/client-state.csv", "role": "structured authority", "v4": "import into SQLite clients then remove"},
    {"path": "meta/client-ip.csv", "role": "structured authority", "v4": "import into SQLite address_assignments then remove"},
    {"path": "meta/audit.jsonl", "role": "structured authority", "v4": "import into SQLite audit_events then remove"},
    {"path": "pki", "role": "PKI authority and certificate artifacts", "v4": "retain as files"},
    {"path": "secrets/tls-crypt.key", "role": "secret artifact", "v4": "retain as file"},
    {"path": "server/server.conf", "role": "derived artifact", "v4": "retain as file and track metadata"},
    {"path": "clients/active", "role": "derived sensitive profiles", "v4": "retain as files and track metadata"},
    {"path": "clients/revoked", "role": "revoked sensitive profiles", "v4": "retain as files and track metadata"},
    {"path": "ccd", "role": "derived static assignment artifacts", "v4": "retain as files and track metadata"},
    {"path": "cache/client-leases", "role": "discardable runtime cache", "v4": "SQLite client_leases cache"},
    {"path": "logs/openvpn.log", "role": "runtime log", "v4": "retain as file"},
    {"path": "logs/events.jsonl", "role": "user event stream", "v4": "retain append-only file"},
    {"path": "repair", "role": "repair evidence and snapshots", "v4": "replace with operation staging/snapshots as applicable"}
  ],
  "render_cases": [
