#!/usr/bin/env bash
set -euo pipefail

[ "$#" -ge 1 ] || exit 64
hook="$1"
shift

case "$hook" in
pool-persist) target="${OVPN_LIB_DIR:-/usr/local/lib/openvpn-container}/pool-persist-hook.sh" ;;
*)
  printf 'ovpn hook: unknown hook %s\n' "$hook" >&2
  exit 64
  ;;
esac

[ -x "$target" ] || {
  printf 'ovpn hook: image does not provide %s\n' "$hook" >&2
  exit 78
}
exec "$target" "$@"
