#!/usr/bin/env bash
set -euo pipefail

LIB_DIR="${OVPN_LIB_DIR:-/usr/local/lib/openvpn-container}"
# shellcheck source=/usr/local/lib/openvpn-container/common.sh
. "$LIB_DIR/common.sh"
. "$LIB_DIR/ipam.sh"
. "$LIB_DIR/config.sh"
. "$LIB_DIR/registry.sh"
. "$LIB_DIR/client_ip.sh"
. "$LIB_DIR/network.sh"
. "$LIB_DIR/render.sh"
. "$LIB_DIR/render_ipam.sh"
. "$LIB_DIR/lock.sh"
. "$LIB_DIR/recovery.sh"
. "$LIB_DIR/state.sh"
. "$LIB_DIR/repair.sh"
. "$LIB_DIR/pki.sh"
. "$LIB_DIR/compatibility.sh"
. "$LIB_DIR/metadata.sh"
. "$LIB_DIR/init.sh"
. "$LIB_DIR/maintenance.sh"
. "$LIB_DIR/start.sh"
. "$LIB_DIR/client.sh"

command="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$command" in
  help|-h|--help)
    ovpn_usage
    ;;
  version|--version)
    ovpn_version
    ;;
  config)
    ovpn_config_command "$@"
    ;;
  client-ip)
    ovpn_client_ip_command "$@"
    ;;
  render)
    ovpn_render_command "$@"
    ;;
  state)
    ovpn_state_command "$@"
    ;;
  init)
    ovpn_init_command "$@"
    ;;
  start)
    ovpn_start_command "$@"
    ;;
  add-client)
    ovpn_add_client_command "$@"
    ;;
  export-client)
    ovpn_export_client_command "$@"
    ;;
  list-clients)
    ovpn_list_clients_command "$@"
    ;;
  revoke-client)
    ovpn_revoke_client_command "$@"
    ;;
  doctor)
    ovpn_doctor_command "$@"
    ;;
  repair)
    ovpn_repair_command "$@"
    ;;
  status)
    ovpn_status_command "$@"
    ;;
  healthcheck)
    ovpn_healthcheck_command "$@"
    ;;
  recover)
    ovpn_not_implemented "$command"
    ;;
  capabilities)
    ovpn_capabilities_command "$@"
    ;;
  *)
    ovpn_log "unknown command '$command'"
    ovpn_usage >&2
    exit 64
    ;;
esac
