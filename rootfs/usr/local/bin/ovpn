#!/usr/bin/env bash
set -euo pipefail

LIB_DIR="${OVPN_LIB_DIR:-/usr/local/lib/openvpn-container}"
# shellcheck source=/usr/local/lib/openvpn-container/common.sh
. "$LIB_DIR/common.sh"

command="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$command" in
  help|-h|--help)
    ovpn_usage
    ;;
  version|--version)
    ovpn_version
    ;;
  start|init|doctor|state|repair|recover|config|render|add-client|export-client|list-clients|revoke-client|status|healthcheck|capabilities)
    ovpn_not_implemented "$command"
    ;;
  *)
    ovpn_log "unknown command '$command'"
    ovpn_usage >&2
    exit 64
    ;;
esac
