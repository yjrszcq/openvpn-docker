#!/usr/bin/env bash
set -euo pipefail

if [ -n "${OVPN_LIB_DIR:-}" ] && [ -x "$OVPN_LIB_DIR/cli.sh" ]; then
  exec "$OVPN_LIB_DIR/cli.sh" "$@"
fi

BOOTSTRAP_LIB="${OVPN_BOOTSTRAP_LIB:-/usr/local/lib/openvpn-bootstrap.sh}"
# shellcheck source=/usr/local/lib/openvpn-bootstrap.sh
. "$BOOTSTRAP_LIB"
ovpn_bootstrap_exec "$@"
